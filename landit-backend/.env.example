# Gemini text models for extraction, scoring, and feedback
GEMINI_API_KEY=your_gemini_api_key_here

# Tavily is optional but recommended for parsing JavaScript-rendered job posts.
# If omitted, the backend falls back to direct HTTP/JSON-LD scraping.
TAVILY_API_KEY=

# App Settings
APP_SECRET_KEY=your_secret_key_here
DEBUG=false

# Supabase Auth — SUPABASE_URL is required (used to fetch JWKS for token verification)
# SUPABASE_JWT_SECRET is optional fallback for legacy HS256 projects
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=

# ─── Database ────────────────────────────────────────────────────────────────
# Local dev (SQLite):
# DATABASE_URL=sqlite+aiosqlite:///./landit.db
#
# Production (Supabase PostgreSQL — Transaction Pooler 推荐):
# 在 Supabase Dashboard → Project Settings → Database → Connection string 中找到
# 格式：Session Mode   → postgresql+asyncpg://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
#       Transaction Pooler → postgresql+asyncpg://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite+aiosqlite:///./landit.db

# File Storage (local dev only — Render 部署时使用 Render Persistent Disk 或 Supabase Storage)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# CORS — 生产时改为 Vercel 域名，多个用逗号分隔
# 示例：ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
