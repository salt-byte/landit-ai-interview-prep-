# Anthropic API
ANTHROPIC_API_KEY=

# App Settings
APP_SECRET_KEY=landit-dev-secret-change-in-prod
DEBUG=false

# Database
# Local dev:
DATABASE_URL=sqlite+aiosqlite:///./landit.db
#
# Supabase production example:
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://aistudio.google.com
ALLOWED_ORIGIN_REGEX=https://.*\.vercel\.app
