# Frontend API base URL
# Local dev can keep this as localhost, or remove it and rely on the built-in default.
# Production example:
# VITE_API_URL=https://landit-ai-interview-prep.onrender.com
VITE_API_URL=http://localhost:8000

# Legacy alias also supported by api.ts if your deployment still uses it.
# VITE_API_BASE_URL=http://localhost:8000
