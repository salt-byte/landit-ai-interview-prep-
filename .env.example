# Frontend API base URL
# Local dev can keep this as localhost, or remove it and rely on the built-in default.
# Production example:
# VITE_API_URL=https://landit-ai-interview-prep.onrender.com
VITE_API_URL=http://localhost:8000

# Supabase Auth — from Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gemini Live voice interview runs in the browser.
# Use a restricted browser key for production.
VITE_GEMINI_API_KEY=your-gemini-api-key
